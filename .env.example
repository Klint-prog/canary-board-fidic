# ── Paperclip — variáveis de ambiente ─────────────────────────────────────────

# Porta exposta no host
PAPERCLIP_PORT=3100

# Senha do PostgreSQL (use a mesma sempre — trocar exige recriar o volume)
POSTGRES_PASSWORD=paperclip

# Segredo de autenticação (gere um aleatório: openssl rand -base64 32)
BETTER_AUTH_SECRET=mude-este-segredo-para-algo-aleatorio

# OpenRouter (usado como provedor de LLM via codex_local adapter)
OPENAI_API_KEY=sk-or-sua-chave-openrouter-aqui

# Anthropic (opcional, para adapter claude_local)
ANTHROPIC_API_KEY=
